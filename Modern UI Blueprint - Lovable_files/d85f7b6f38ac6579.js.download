v/integrations/snowflake",date:"2026-04-21T09:00:00.000Z"},{id:"connectors-microsoft-365",title:"Microsoft 365 connectors are here",description:"Connect Outlook, Word, Excel, PowerPoint, Teams, OneDrive, and OneNote through Microsoft 365, straight from Lovable.",imageUrl:"/img/announcements/connectors-microsoft.png",buttonEndpoint:"https://docs.lovable.dev/integrations/introduction",date:"2026-04-19T09:00:00.000Z"},{id:"connectors-inngest",title:"Inngest connector is here",description:"Integrate Inngest to send events, run durable workflows, and schedule background jobs from your Lovable app.",imageUrl:"/img/announcements/connectors-inngest.png",buttonEndpoint:"https://docs.lovable.dev/integrations/inngest",date:"2026-04-17T09:00:00.000Z"},{id:"connectors-hubspot",title:"HubSpot connector is here",description:"Integrate HubSpot to sync CRM contacts, deals, and pipelines, and automate sales workflows from your Lovable app.",imageUrl:"/img/announcements/connectors-hubspot.png",buttonEndpoint:"https://docs.lovable.dev/integrations/hubspot",date:"2026-04-15T09:00:00.000Z"},{id:"lovable-payments",title:"Lovable Payments are here",description:"Describe what you want to sell. Test it securely. One conversation to go live. Just ask Lovable to add payments to get started.",imageUrl:"/img/announcements/launch-graphic-payments.png",buttonEndpoint:"https://docs.lovable.dev/features/payments",date:"2026-04-13T15:00:00.000Z"},{id:"connectors-bigquery",title:"BigQuery connector is here",description:"Integrate BigQuery to run SQL, explore datasets, and analyze data in Google Cloud from your Lovable app.",imageUrl:"/img/announcements/connectors-bigquery.png",buttonEndpoint:"https://docs.lovable.dev/integrations/bigquery",date:"2026-04-13T09:00:00.000Z"},{id:"changelog-apr-2-2026",title:"Latest Lovable updates – April 2, 2026",description:"Take a look at all the latest features, improvements, and bug fixes in Lovable. Check out the full changelog.",imageUrl:"/img/announcements/LovableChangelog.png",buttonEndpoint:"https://docs.lovable.dev/changelog#apr-2-2026",date:"2026-04-02T07:00:00.000Z"},{id:"aikido-connector-pentesting",title:"Pentesting available for every project",description:"Prove your projects are secure with a pentest, powered by Aikido.",imageUrl:"/img/announcements/lovable-aikido.png",buttonEndpoint:"https://lovable.dev/blog/announcing-pentesting",date:"2026-03-25T15:50:00.000Z"},{id:"lovable-emails",title:"Send branded emails from your domain",description:"Every email builds trust. Connect your domain to send branded emails, straight from Lovable.",imageUrl:"/img/announcements/lovable-emails.png",buttonEndpoint:"https://docs.lovable.dev/features/custom-emails",date:"2026-03-24T11:29:39.000Z"},{id:"go-beyond-building-apps",title:"Go beyond building apps with Lovable",description:"Analyze data, create files, generate docs, and turn spreadsheets into working apps — all without leaving Lovable.",imageUrl:"/img/announcements/go-beyond-building.png",buttonEndpoint:"https://lovable.dev/blog/go-beyond-building-full-stack-apps-with-lovable",date:"2026-03-19T16:50:00.000Z"},{id:"connectors-linear",title:"Linear connector is here",description:"Integrate Linear to manage your project roadmap and track your team's progress.",imageUrl:"/img/announcements/connector-linear.png",buttonEndpoint:"https://docs.lovable.dev/integrations/linear",date:"2026-03-18T09:00:00.000Z"},{id:"connectors-twitch",title:"Twitch connector is here",description:"Integrate Twitch to build custom stream overlay, access stream data, manage channels, and interact with the Twitch API from your Lovable app.",imageUrl:"/img/announcements/connector-twitch.png",buttonEndpoint:"https://docs.lovable.dev/integrations/twitch",date:"2026-03-17T09:00:00.000Z"},{id:"changelog-mar-16-2026",title:"Latest Lovable updates – March 16, 2026",description:"Take a look at all the latest features, improvements, and bug fixes in Lovable. Check out the full changelog.",imageUrl:"/img/announcements/LovableChangelog.png",buttonEndpoint:"https://docs.lovable.dev/changelog#mar-16-2026",date:"2026-03-16T11:04:18.000Z"},{id:"connectors-contentful",title:"Contentful connector is here",description:"Integrate Contentful to build dynamic content-driven apps.",imageUrl:"/img/announcements/connector-contentful.png",buttonEndpoint:"https://docs.lovable.dev/integrations/contentful",date:"2026-03-16T09:00:00.000Z"},{id:"connectors-telegram",title:"Telegram connector is here",description:"Integrate Telegram to send messages, manage channels, and interact with the Telegram API from your Lovable app.",imageUrl:"/img/announcements/connector-telegram.png",buttonEndpoint:"https://docs.lovable.dev/integrations/telegram",date:"2026-03-13T09:00:00.000Z"},{id:"connectors-twilio",title:"Twilio connector is here",description:"Integrate Twilio to send SMS messages, make voice calls, and manage communication workflows from your Lovable app.",imageUrl:"/img/announcements/connector-twilio.png",buttonEndpoint:"https://docs.lovable.dev/integrations/twilio",date:"2026-03-12T09:00:00.000Z"},{id:"changelog-feb-23-2026",title:"Latest Lovable updates – February 23, 2026",description:"Take a look at all the latest features, improvements, and bug fixes in Lovable. Check out the full changelog.",imageUrl:"/img/announcements/LovableChangelog.png",buttonEndpoint:"https://docs.lovable.dev/changelog#feb-23-2026",date:"2026-02-23T10:24:55.000Z"},{id:"cross-project-referencing",title:"Cross-project referencing is here",description:"Lovable can now reuse code, components, and features across projects in your workspace.",imageUrl:"/img/announcements/cross-project.webp",buttonEndpoint:"https://docs.lovable.dev/features/cross-project-referencing",date:"2026-02-18T17:00:00.000Z"},{id:"connectors-slack",title:"Slack connector is here",description:"Add Slack notifications, alerts, and channel updates directly into your app.",imageUrl:"/img/announcements/slack-connector.png",buttonEndpoint:"https://docs.lovable.dev/integrations/slack",date:"2026-02-16T14:00:00.000Z"},{id:"changelog-feb-5-2026",title:"Latest Lovable updates – February 5, 2026",description:"Take a look at all the latest features, improvements, and bug fixes in Lovable. Check out the full changelog.",imageUrl:"/img/announcements/LovableChangelog.png",buttonEndpoint:"https://docs.lovable.dev/changelog#feb-5%2C-2026",date:"2026-02-05T09:47:54.000Z"},{id:"linkedin-vibe-coding-levels",title:"Show off your vibe coding skills on LinkedIn",description:"Unlock badges as you build and showcase your vibe coding momentum on your LinkedIn profile.",imageUrl:"/img/announcements/vibe-code-linkedin.webp",buttonEndpoint:"https://docs.lovable.dev/tips-tricks/linkedin-certification",date:"2026-02-03T10:00:00.000Z"},{id:"agent-v2-release",title:"Build more. Manage less.",description:"Lovable now handles complex builds more autonomously.",imageUrl:"/img/announcements/agent-launch-queuing.jpg",buttonEndpoint:"https://lovable.dev/a-smarter-lovable",date:"2026-01-28T16:00:00.000Z"},{id:"changelog-jan-16-2026",title:"Latest Lovable updates – January 16, 2026",description:"Take a look at all the latest features, improvements, and bug fixes in Lovable. Check out the full changelog.",imageUrl:"/img/announcements/LovableChangelog.png",buttonEndpoint:"https://docs.lovable.dev/changelog#jan-16%2C-2026",date:"2026-01-16T15:45:56.000Z"},{id:"build-credit-topups",title:"Top up credits on demand",description:"Need more credits? Buy one-time top-ups in 50-credit increments from Plans & credits. Pro & Business plans. Valid 12 months.",imageUrl:"/img/announcements/credits-top-up.png",buttonEndpoint:"https://docs.lovable.dev/introduction/plans-and-credits#credit-top-ups",date:"2026-01-15T09:00:00.000Z",shouldShow:({workspace:e})=>{let{isProPlan:t,isBizPlan:n}=(0,s.isWhatPlan)(e.plan);return t||n}},{id:"changelog-dec-23-2025",title:"Latest Lovable updates – December 23, 2025",description:"Take a look at all the latest features, improvements, and bug fixes in Lovable. Check out the full changelog.",imageUrl:"/img/announcements/LovableChangelog.png",buttonEndpoint:"https://docs.lovable.dev/changelog#dec-23%2C-2025",date:"2025-12-23T14:06:07.000Z"},{id:"connectors-elevenlabs-perplexity-firecrawl",title:"ElevenLabs, Perplexity & Firecrawl",description:"Power your apps with voice, real-time research, and web scraping - now available via new connectors in Lovable.",imageUrl:"/img/announcements/connectors.png",buttonEndpoint:"https://lovable.dev/blog/ai-connectors",date:"2025-12-16T09:00:00.000Z"},{id:"changelog-dec-10-2025",title:"Latest Lovable updates – December 10, 2025",description:"Take a look at all the latest features, improvements, and bug fixes in Lovable. Check out the full changelog.",imageUrl:"/img/announcements/LovableChangelog.png",buttonEndpoint:"https://docs.lovable.dev/changelog#dec-10%2C-2025",date:"2025-12-10T09:00:00.000Z"},{id:"chat-mode-clarifying-questions",title:"Plan before you build",description:"Start in Chat Mode to explore ideas before writing any code. Lovable now also asks questions, for less back-and-forth later.",imageUrl:"/img/announcements/questions-main.jpg",buttonEndpoint:"https://lovable.dev/blog/chat-mode-and-questions",date:"2025-12-05T09:00:00.000Z"},{id:"dashboard-v2",title:"Your dashboard just got more Lovable",description:"We've redesigned your dashboard to make it faster to find what you need and discover what's next.",imageUrl:"/img/announcements/dashboard-2-whats-new.png",date:"2025-12-03T09:00:00.000Z"},{id:"opus-4-5",title:"Chat mode powered by Claude Opus 4.5",description:"Get early access to Claude Opus 4.5 in Chat Mode. Test the newest, most powerful reasoning model in your builds through December 5th.",imageUrl:"/img/announcements/opus-4-5.png",buttonEndpoint:"https://lovable.dev/blog/claude-opus-4-5-in-chat",date:"2025-11-24T19:30:00.000Z"},{id:"themes-visual-edits",title:"Customize your app with design tools",description:"Introducing brand-new Themes and upgraded Visual edits—now unified in the new Design view, giving you one powerful place to customize your project visually, no code needed.",imageUrl:"/img/announcements/themes-release.webp",buttonEndpoint:"https://docs.lovable.dev/features/design",date:"2025-11-18T00:00:00.000Z"},{id:"mcps-release",title:"Connect MCP servers",description:"Connect Lovable to your team's tools and enable context-driven creation — moving from idea to validation to live app faster than ever. Pull in real data from Atlassian (Jira, Confluence), Notion, Linear, and n8n directly into your app building workflow.",imageUrl:"/img/announcements/mcps-release-x7k9m2p4q.webp",buttonEndpoint:"https://docs.lovable.dev/integrations/mcp-servers",date:"2025-11-17T00:00:00.000Z"},{id:"better-reverts",title:"Revert and edit messages in chat",description:'"Restore" is now "Revert". Revert your project to any point in your chat history, or edit a past message to revert and explore a new direction. Nothing gets lost — all changes made after that point stay in the chat and can be reapplied anytime.',imageUrl:"/content/news/covers/editing-messages.png",date:"2025-11-13T00:00:00.000Z"},{id:"internal-publish",title:"Internal apps, made simple",description:"Share apps inside your org without extra setup. Workspace publishing restricts access to authenticated teammates and includes unlimited view-only seats. Available on Business and Enterprise.",imageUrl:"/content/news/covers/internal-publish-heart-inbox.png",buttonEndpoint:"https://docs.lovable.dev/features/publish",date:"2025-11-05T00:00:00.000Z",shouldShow:({workspace:e})=>{let{isBizPlan:t,isEnterprisePlan:n}=(0,s.isWhatPlan)(e.plan);return t||n}},{id:"shopify-integration",title:"The Lovable Shopify integration",description:"You can now build and launch a fully functional Shopify store right from Lovable. Just describe your idea, and Lovable instantly designs your storefront, sets up checkout, and connects it to Shopify.",imageUrl:"/img/announcements/lovable-shopify.jpg",buttonEndpoint:"/blog/shopify-integration",date:"2025-10-20T12:00:00.000Z"},{id:"lovable-cloud-ga-pricing",title:"Lovable Cloud and AI",description:"Lovable Cloud gives you database, auth, storage, and backend logic out of the box. Lovable AI adds LLM-powered chat, automation, and content generation with zero setup, with free usage included and top ups in Settings → Usage.",imageUrl:"/content/news/covers/cloud-release.jpg",buttonEndpoint:"https://lovable.dev/blog/lovable-cloud",date:"2025-09-29T12:00:00.000Z"},{id:"navigation-updates",description:"Analytics, Speed, and Security have been moved from settings to the project view switcher for easier access.",imageUrl:"/content/news/covers/navigation.jpg",title:"Explore the new layout",date:"2025-09-30T11:00:00.000Z"},{id:"file-uploads",description:"Multi-format uploads are here: CSV, PDF, TTF, MP4, and more.",imageUrl:"/content/news/covers/file-upload.png",title:"File uploads are here",buttonEndpoint:"https://lovable.dev/blog/lovable-file-uploads",date:"2025-09-24T15:00:00.000Z"},{id:"voice-mode",description:"Talk to Lovable naturally - describe what you want to build in speech instead of typing. Voice mode makes building apps as easy as having a conversation.",imageUrl:"/content/news/covers/voice-mode.png",title:"Voice mode is here",buttonEndpoint:"https://x.com/Lovable/status/1963255845900484632",date:"2025-09-02T12:00:00.000Z"},{id:"in-app-seo",description:"Lovable bakes in SEO from day one - auto-optimized tags, structured data, image alt text, clean URLs, and page speed tuning so your site ranks fast without extra setup.",imageUrl:"/content/news/covers/in-app-seo.png",title:"Automatic in-app SEO",buttonEndpoint:"https://docs.lovable.dev/features/seo",date:"2025-08-28T12:00:00.000Z"},{id:"lovable-security",description:"Real-time protection, 1,000+ risky projects blocked daily, and new SOC 2 Type II & ISO 27001 certifications.",imageUrl:"/content/news/covers/certifications-cropped.png",title:"Vibe coding meets security",buttonEndpoint:"/blog/lovable-security",date:"2025-08-19T09:00:00.000Z"},{id:"student-discount",description:"Verify your student status with your educational email or student ID to get instant access to 50% off Lovable Pro",imageUrl:"/content/news/covers/student-discount.png",title:"Student Discount 50% off",buttonEndpoint:"/students",date:"2025-08-13T00:00:00.000Z"},{id:"rollovers",description:`
    No more "use it or lose it."
    Monthly plans rollover up to your credit limit, annual plans up to 12\xd7 monthly limit.
    Free daily credits don't roll over - use them before the day ends.
    `,imageUrl:"/content/news/covers/credits-rollover.png",title:"Credit Rollovers Are Here",buttonEndpoint:"https://docs.lovable.dev/introduction/plans-and-credits",date:"2025-08-07T00:00:00.000Z",shouldShow:({workspace:e})=>{let{isProPlan:t,isBizPlan:n}=(0,s.isWhatPlan)(e.plan);return t||n}},{id:"series-a-funding",description:"We have been extremely selective in our fundraising process. We will use this money to hire the best talent in Europe and keep making the product even better.",imageUrl:"/content/news/covers/series-a.png",title:"Read About Our $200m Series A",buttonEndpoint:"/blog/200m-series-a-fundraise",date:"2025-07-17T00:00:00.000Z"},{id:"agent-mode",description:"Lovable 2.0 introduces Agent Mode, an agent-first AI interface for deploying and managing your projects.",imageUrl:"/content/news/covers/agent-new.png",title:"Try agent mode",buttonEndpoint:"/blog/agent",date:"2025-07-23T00:00:00.000Z"}];e.s(["announcements",0,r],127835);var a=e.i(617456),o=e.i(396599),i=e.i(491917),l=e.i(412328),d=e.i(608534);function c(){let{workspace:e}=(0,n.useCurrentWorkspace)(),s=(0,l.useFlags)(),c=(0,i.useFlagOverridesStore)(e=>e.overrides),u=(0,a.useCanAccessAdminFeatures)();return(0,t.useMemo)(()=>{if(!e)return[];let t={isEnabled:e=>{let t=(0,o.getFlagDefault)(e),{value:n}=(0,d.getFlagValue)(e,s,c,t),r=(0,d.validateBooleanFlagValue)(n,t);return(0,d.enforceInternalFlag)(e,r,t,u)}};return r.filter(n=>!(n.date>new Date().toISOString())&&(null==n.shouldShow||n.shouldShow({workspace:e,flags:t})))},[e,s,c,u])}e.s(["useFilteredAnnouncements",()=>c],865224)},817540,639462,371910,e=>{"use strict";var t=e.i(141901),n=e.i(482480);e.i(601920);var s=e.i(951066),r=e.i(106798),a=e.i(520825),o=e.i(22925),i=e.i(292719),l=e.i(413543),d=e.i(162302),c=e.i(370660),u=e.i(763381);let p=({onAccept:e,onDecline:n,isAccepting:s=!1,isDeclining:r=!1,acceptLabel:a="Accept",declineLabel:o="Decline"})=>{let i=(0,u.useIsMobileViewport)(),l=s||r;return(0,t.jsxs)("div",{className:"flex gap-2",children:[(